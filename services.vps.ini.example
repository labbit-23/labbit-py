[service:oracle_db]
type = tcp
enabled = 1
run_on = vps
category = database
label = Oracle DB
host = 120.138.8.37
port = 1521
timeout_seconds = 4
slow_threshold_ms = 1200
interval_seconds = 60

[service:tomcat_7]
type = tcp
enabled = 1
run_on = vps
category = app
label = Tomcat 7
host = 120.138.8.37
port = 9999
timeout_seconds = 4
slow_threshold_ms = 1200
interval_seconds = 60

[service:tomcat_9]
type = tcp
enabled = 1
run_on = vps
category = app
label = Tomcat 9
host = 120.138.8.37
port = 7777
timeout_seconds = 4
slow_threshold_ms = 1200
interval_seconds = 60

[service:local_delivery_engine]
type = heartbeat_file
enabled = 0
run_on = both
category = python
label = Delivery Engine Heartbeat
path = /var/tmp/fetchreports/delivery_engine_heartbeat.json
max_age_seconds = 300
interval_seconds = 30

[service:monitoring_agent]
type = heartbeat_file
enabled = 0
run_on = both
category = python
label = Monitoring Agent Heartbeat
path = /var/tmp/fetchreports/monitoring_agent_heartbeat.json
max_age_seconds = 180
interval_seconds = 30

[service:machine_bridge]
type = heartbeat_file
enabled = 0
run_on = both
category = python
label = Machine Bridge
path = /var/tmp/fetchreports/machine_bridge_heartbeat.json
max_age_seconds = 300
interval_seconds = 30
