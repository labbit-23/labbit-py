[monitoring]
enabled = 1
lab_id = b539c161-1e2b-480b-9526-d4b37bd37b1e
source = neosoft-edge-1-local
node_role = local
ingest_url = https://lab.sdrc.in/api/cto/ingest
ingest_token = PUT_CTO_INGEST_TOKEN_HERE
interval_seconds = 60
scheduler_tick_seconds = 15
request_timeout_seconds = 8

[group:internet_edge]
run_on = local
label = Internet / WAN
services = mirth_lab,mirth_dicom,orthanc_main
failure_condition = all_down
severity = critical
message = Likely internet, VPN, or upstream network issue

[group:local_edge]
run_on = local
label = Local Edge / Python
services = monitoring_agent,auto_send_reports,machine_bridge,ecg_sender,dicom_worker
failure_condition = majority_down
severity = high
message = Likely local edge system or LAN issue

[group:machine_interfacing]
run_on = local
label = Machine Interfacing
services = mirth_lab,mirth_dicom,orthanc_main
failure_condition = any_down
severity = high
message = Likely Mirth, DICOM, or machine interfacing issue

[service:mirth_dicom]
type = http_json
enabled = 1
run_on = local
category = mirth
label = Mirth DICOM
url = https://100.103.168.62:8443/api/server/version
method = GET
expected_status = 200
slow_threshold_ms = 2000
verify_ssl = 0
header_x_requested_with = OpenAPI
interval_seconds = 60

[service:mirth_lab]
type = http_json
enabled = 1
run_on = local
category = mirth
label = Mirth Lab
url = https://100.71.105.110:8443/api/server/version
method = GET
expected_status = 200
slow_threshold_ms = 2000
verify_ssl = 0
header_x_requested_with = OpenAPI
interval_seconds = 60

[service:orthanc_main]
type = http_json_auth
enabled = 1
run_on = local
category = orthanc
label = Orthanc Main
url = http://100.84.172.71:8042/system
method = GET
username = radio
password = radio
expected_status = 200
slow_threshold_ms = 2000
interval_seconds = 120

[service:funnel_mirth_public]
type = tcp
enabled = 1
run_on = local
category = public_ingress
label = Funnel Public HTTPS
host = sdrc.tail950b5e.ts.net
port = 8000
timeout_seconds = 4
slow_threshold_ms = 1000
interval_seconds = 60

[service:funnel_mirth_health]
type = http_json
enabled = 1
run_on = local
category = python
label = Funnel Health Endpoint
url = https://sdrc.tail950b5e.ts.net/health
method = GET
expected_status = 200
slow_threshold_ms = 2000
interval_seconds = 60

[service:local_delivery_engine]
type = heartbeat_file
enabled = 0
run_on = both
category = python
label = Delivery Engine Heartbeat
path = /var/tmp/fetchreports/delivery_engine_heartbeat.json
max_age_seconds = 300
interval_seconds = 30

[service:monitoring_agent]
type = heartbeat_file
enabled = 0
run_on = both
category = python
label = Monitoring Agent Heartbeat
path = /var/tmp/fetchreports/monitoring_agent_heartbeat.json
max_age_seconds = 180
interval_seconds = 30

[service:auto_send_reports]
type = heartbeat_file
enabled = 0
run_on = local
category = python
label = Auto Send Reports
path = /var/tmp/fetchreports/auto_send_reports_heartbeat.json
max_age_seconds = 300
interval_seconds = 30

[service:machine_bridge]
type = heartbeat_file
enabled = 0
run_on = both
category = python
label = Machine Bridge
path = /var/tmp/fetchreports/machine_bridge_heartbeat.json
max_age_seconds = 300
interval_seconds = 30

[service:ecg_sender]
type = heartbeat_file
enabled = 0
run_on = local
category = python
label = ECG Sender
path = /var/tmp/fetchreports/ecg_sender_heartbeat.json
max_age_seconds = 300
interval_seconds = 30

[service:dicom_worker]
type = heartbeat_file
enabled = 0
run_on = local
category = python
label = DICOM Worker
path = /var/tmp/fetchreports/dicom_worker_heartbeat.json
max_age_seconds = 300
interval_seconds = 30

# Mirth channel-level monitoring stubs (local)
[service:mirth_channel_01]
type = http_json
enabled = 0
run_on = local
category = mirth
label = Mirth Channel 01
url = https://100.71.105.110:8443/api/channels/<channel-id-01>/status
method = GET
expected_status = 200
slow_threshold_ms = 2000
verify_ssl = 0
header_x_requested_with = OpenAPI
interval_seconds = 60

